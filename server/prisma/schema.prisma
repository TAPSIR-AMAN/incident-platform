generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  USER
}

enum IncidentStatus {
  OPEN
  ACKNOWLEDGED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users     User[]
  incidents Incident[]
}

model User {
  id           String @id @default(cuid())
  tenantId     String
  name         String
  email        String @unique
  passwordHash String
  role         Role

  tenant Tenant @relation(fields: [tenantId], references: [id])

  createdIncidents  Incident[] @relation("CreatedIncidents")
  assignedIncidents Incident[] @relation("AssignedIncidents")

  createdAt DateTime @default(now())
}

model Incident {
  id          String         @id @default(cuid())
  tenantId    String
  title       String
  description String
  status      IncidentStatus @default(OPEN)
  version     Int            @default(1)

  createdById  String
  assignedToId String?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  createdBy User @relation("CreatedIncidents", fields: [createdById], references: [id])

  assignedTo User? @relation("AssignedIncidents", fields: [assignedToId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  comments  Comment[]
}

model Comment {
  id String @id @default(cuid())

  tenantId   String
  incidentId String
  userId     String

  message String

  incident Incident @relation(fields: [incidentId], references: [id])

  createdAt DateTime @default(now())
}

model AuditLog {
  id String @id @default(cuid())

  tenantId   String
  incidentId String
  userId     String

  action  String
  details String?

  createdAt DateTime @default(now())
}
